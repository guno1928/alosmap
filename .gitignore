# Allowlist: this repository contains only the production library source.
# Everything is ignored by default; production files are re-included below.
# Build artifacts, profiles, benchmark output, scratch docs, and tests stay local.

/*

!/.gitignore
!/go.mod
!/go.sum
!/README.md
!/doc.go
!/map.go
!/hash.go
!/fastcell.go
!/modifiers.go
!/rangefast.go
!/typedmap.go
!/typedmap_ext.go
!/typedmap_ext_test.go
!/typedmap_testall.go
!/typedmap_exttestall.go
!/testall.go
!/testall_test.go
!/iface_amd64.go
!/iface_amd64.s
!/prefetch_amd64.go
!/prefetch_amd64.s
!/prefetch_generic.go

# Benchmark suite (separate module). Its own .gitignore drops results/.
!/benchmarks/
!/benchmarks/**
